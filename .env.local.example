# Скопіюй цей файл у .env.local і встав свої ключі.

# --- Розбір тексту в задачі (LLM через OpenRouter) ---
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
# Модель для розбору. За замовчуванням Llama 3.3 70B.
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# --- Розпізнавання голосу (STT через Groq Whisper) ---
# Безкоштовний ключ із console.groq.com (без картки). Використовується лише на сервері.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
# Опційно: модель STT (за замовчуванням whisper-large-v3)
GROQ_STT_MODEL=whisper-large-v3
